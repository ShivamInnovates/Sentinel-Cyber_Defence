# ========================================================================================
# TRINETRA Cyber Defense - Development Environment Variables
# ========================================================================================
# Local development configuration

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

TRINETRA_API_KEY=TRINETRA-demo-key
ALLOWED_ORIGINS=*

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis-password
REDIS_DB=0

BACKEND_HOST=backend
BACKEND_PORT=8000
DATA_DIR=/app/data
REFERENCE_SCREENSHOTS_DIR=/app/reference_screenshots
SCREENSHOTS_DIR=/app/screenshots

FRONTEND_PORT=80
VITE_API_BASE_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

LEVENSHTEIN_THRESHOLD=65
KEYWORD_MIN_COUNT=2

COMPOSITE_CONFIRMED=75
COMPOSITE_PROBABLE=50
ZSCORE_RED=3.0
ZSCORE_YELLOW=2.5
ADMIN_OFFHOURS_START=22
ADMIN_OFFHOURS_END=6
BASE_LOGIN_PER_HOUR=48

BRIDGE_AUTO_HOURS=4
BRIDGE_REVIEW_DAYS=7
