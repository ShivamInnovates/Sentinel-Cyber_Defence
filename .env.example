# ========================================================================================
# TRINETRA Cyber Defense - Environment Configuration
# ========================================================================================
# This file contains default environment variables for development
# For production, create a .env.prod file with secure values
# NEVER commit secrets or sensitive data to version control!

# ─────────────────────────────────────────────────────────────────────────────────────
# Deployment Environment
# ─────────────────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────────────
# API Security
# ─────────────────────────────────────────────────────────────────────────────────────
TRINETRA_API_KEY=TRINETRA-demo-key
ALLOWED_ORIGINS=*

# ─────────────────────────────────────────────────────────────────────────────────────
# Redis Cache Configuration
# ─────────────────────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis-password
REDIS_DB=0

# ─────────────────────────────────────────────────────────────────────────────────────
# Backend Service Configuration
# ─────────────────────────────────────────────────────────────────────────────────────
BACKEND_HOST=backend
BACKEND_PORT=8000
DATA_DIR=/app/data
REFERENCE_SCREENSHOTS_DIR=/app/reference_screenshots
SCREENSHOTS_DIR=/app/screenshots

# ─────────────────────────────────────────────────────────────────────────────────────
# Frontend Service Configuration
# ─────────────────────────────────────────────────────────────────────────────────────
FRONTEND_PORT=80
VITE_API_BASE_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

# ─────────────────────────────────────────────────────────────────────────────────────
# Model Thresholds (Drishti - Phishing Detection)
# ─────────────────────────────────────────────────────────────────────────────────────
LEVENSHTEIN_THRESHOLD=65
KEYWORD_MIN_COUNT=2

# ─────────────────────────────────────────────────────────────────────────────────────
# Model Thresholds (Kavach - Anomaly Detection)
# ─────────────────────────────────────────────────────────────────────────────────────
COMPOSITE_CONFIRMED=75
COMPOSITE_PROBABLE=50
ZSCORE_RED=3.0
ZSCORE_YELLOW=2.5
ADMIN_OFFHOURS_START=22
ADMIN_OFFHOURS_END=6
BASE_LOGIN_PER_HOUR=48

# ─────────────────────────────────────────────────────────────────────────────────────
# Model Thresholds (Bridge - Correlation Analysis)
# ─────────────────────────────────────────────────────────────────────────────────────
BRIDGE_AUTO_HOURS=4
BRIDGE_REVIEW_DAYS=7

# ─────────────────────────────────────────────────────────────────────────────────────
# Advanced Domain & Portal Configuration (Comma-separated)
# ─────────────────────────────────────────────────────────────────────────────────────
# REAL_DOMAINS=mcdonline,mcdpropertytax,mcdwatertax
# MCD_KEYWORDS=mcd,delhi,nagar,nigam
# PORTALS=property_tax,water_tax,birth_death,trade_licence
# REAL_PORTAL_URLS=property_tax:https://mcdonline.nic.in/propertytax,water_tax:https://mcdonline.nic.in/watertax

# ─────────────────────────────────────────────────────────────────────────────────────
# Database Configuration (for future use)
# ─────────────────────────────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@db:5432/trinetra
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# ─────────────────────────────────────────────────────────────────────────────────────
# Logging Configuration
# ─────────────────────────────────────────────────────────────────────────────────────
# LOG_FILE=/app/logs/trinetra.log
# LOG_MAX_SIZE=10485760
# LOG_BACKUP_COUNT=5

# ─────────────────────────────────────────────────────────────────────────────────────
# Monitoring & Observability
# ─────────────────────────────────────────────────────────────────────────────────────
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000
# JAEGER_HOST=localhost
# JAEGER_PORT=6831
